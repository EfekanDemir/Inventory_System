# =============================================
# .gitignore — campus-management-system
# Java 17 | Maven 3.9.x | Docker
# =============================================

# ---- Java ----
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# ---- Maven ----
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ---- Spring Boot ----
HELP.md
!**/src/main/**/target/
!**/src/test/**/target/

# ---- IDE: IntelliJ IDEA ----
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ---- IDE: Eclipse ----
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# ---- IDE: VS Code ----
.vscode/
*.code-workspace

# ---- IDE: NetBeans ----
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ---- Docker ----
.docker/
docker-compose.override.yml

# ---- Logs ----
*.log
logs/
log/

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Environment / Secrets ----
.env
.env.*
!.env.example
*.secret
application-local.yml
application-local.properties

# ---- Test Reports ----
/test-results/
/surefire-reports/

# ---- k6 (Performans Testi) ----
k6-tests/reports/*.json
k6-tests/reports/*.csv

# ---- Android & Gradle ----
.gradle/
**/build/
*.apk
*.aab
*.ap_
local.properties
android-app/.gradle/
android-app/build/
android-app/app/build/
android-app/captures/
android-app/.externalNativeBuild/
android-app/.cxx/
android-app/local.properties
*.dex
*.class


# ---- Markdown ----
*.md
!README.md
!CONTRIBUTING.md
!k6-tests/reports/performance-report.md
target/ 
