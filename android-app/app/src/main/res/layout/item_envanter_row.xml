<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Üst satır: kod badge + stok sayısı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardItemCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/colorPrimaryLight"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/tvItemCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="ITM-001"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvStockQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/colorSuccess" />

            <TextView
                android:id="@+id/tvStockLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" adet"
                android:textSize="12sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Ürün adı -->
        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ürün Adı"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:layout_marginTop="6dp" />

        <!-- Alt satır: stok durumu badge + aksiyon butonları -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStockStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="4dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/tvStockStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="YETERLİ"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Hareket butonu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMovement"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Hareket"
                android:textSize="11sp"
                android:paddingHorizontal="10dp"
                app:strokeColor="@color/colorPrimary"
                android:textColor="@color/colorPrimary"
                android:layout_marginEnd="6dp" />

            <!-- Düzenle butonu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Düzenle"
                android:textSize="11sp"
                android:paddingHorizontal="10dp"
                app:strokeColor="@color/colorAccent"
                android:textColor="@color/colorAccent"
                android:layout_marginEnd="6dp" />

            <!-- Sil butonu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Sil"
                android:textSize="11sp"
                android:paddingHorizontal="10dp"
                app:strokeColor="@color/colorError"
                android:textColor="@color/colorError" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
